{
  "name": "kramme-cc-workflow-installer",
  "version": "0.25.0",
  "private": true,
  "description": "Root entrypoint for npx GitHub installs",
  "license": "MIT",
  "bin": {
    "kramme-cc-workflow": "kramme-cc-workflow/scripts/convert-plugin.js"
  },
  "scripts": {
    "check:pre-commit": "make -C kramme-cc-workflow pre-commit",
    "format:check": "make -C kramme-cc-workflow format-check",
    "lint-js": "make -C kramme-cc-workflow lint-js",
    "preflight": "make -C kramme-cc-workflow preflight",
    "test": "make -C kramme-cc-workflow test",
    "test:node:file": "node --test",
    "test:node:watch": "make -C kramme-cc-workflow test-node-watch",
    "test:smoke": "make -C kramme-cc-workflow test-smoke",
    "verify": "make -C kramme-cc-workflow verify",
    "verify:pr": "make -C kramme-cc-workflow pr-verify"
  },
  "dependencies": {
    "smol-toml": "^1.7.0",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@types/node": "^18.19.130",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.18.1",
    "typescript": "^6.0.3"
  }
}
