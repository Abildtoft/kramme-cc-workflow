+/**
+ * Validate and sanitize user registration input.
+ * Checks email format, password strength, and username constraints.
+ */
+export function validateRegistration(input: {
+  email: string;
+  password: string;
+  username: string;
+}): ValidationResult<{ email: string; password: string; username: string }> {
+  const schema = z.object({
+    email: z.string().email(),
+    password: z.string().min(8).regex(/[A-Z]/).regex(/[0-9]/),
+    username: z.string().min(3).max(30).regex(/^[a-zA-Z0-9_-]+$/),
+  });
+
+  const result = schema.safeParse(sanitizeInput(input));
+  if (!result.success) {
+    return { success: false, error: result.error.format() };
+  }
+  return { success: true, data: result.data };
+}
