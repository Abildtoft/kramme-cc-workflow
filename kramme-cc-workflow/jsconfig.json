{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "module": "commonjs",
    "moduleResolution": "node10",
    "noImplicitAny": false,
    "noEmit": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "types": ["node"],
    "useUnknownInCatchVariables": false
  },
  "include": [
    "scripts/convert-plugin/loader.js",
    "scripts/convert-plugin/codex-transformer.js",
    "scripts/convert-plugin/codex-writer.js",
    "hooks/skill-usage.js",
    "evals/skill-review/run-eval.js"
  ]
}
