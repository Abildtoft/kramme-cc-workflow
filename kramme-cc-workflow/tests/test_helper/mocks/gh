#!/bin/bash
# Mock GitHub CLI for testing context-links.sh
# Control behavior via environment variables:
#   MOCK_GH_PR_EXISTS - set to any value to indicate PR exists
#   MOCK_GH_PR_NUMBER - PR number to return
#   MOCK_GH_REQUIRE_PROMPT_DISABLED - require GH_PROMPT_DISABLED=1
#   MOCK_GH_SLEEP_SECONDS - sleep before responding
#   MOCK_GH_CHILD_MARKER - marker path for a background child leak check

case "$*" in
  "pr view --json url,number")
    if [ -n "${MOCK_GH_REQUIRE_PROMPT_DISABLED:-}" ] && [ "${GH_PROMPT_DISABLED:-}" != "1" ]; then
      exit 3
    fi
    if [ -n "${MOCK_GH_CHILD_MARKER:-}" ]; then
      sh -c 'sleep "$1"; printf alive > "$2"' sh "${MOCK_GH_CHILD_SLEEP_SECONDS:-0.2}" "$MOCK_GH_CHILD_MARKER" &
      wait
    fi
    if [ -n "${MOCK_GH_SLEEP_SECONDS:-}" ]; then
      sleep "$MOCK_GH_SLEEP_SECONDS"
    fi
    if [ -n "$MOCK_GH_PR_EXISTS" ]; then
      echo '{"url":"https://github.com/user/repo/pull/'"${MOCK_GH_PR_NUMBER:-1}"'","number":'"${MOCK_GH_PR_NUMBER:-1}"'}'
      exit 0
    else
      exit 1
    fi
    ;;
  *)
    exit 1
    ;;
esac
